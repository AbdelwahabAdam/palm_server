pipeline {
    agent any
    
    triggers {
        pollSCM '*/5 * * * *'
    }
    
    environment {
        DOCKER_USER = 'abdelwahabadam'
        IMAGE_TAG = "${BUILD_NUMBER}"
        DOCKER_CREDENTIALS = credentials('docker-credentials')
    }
    
    stages {
        stage('Docker Login') {
            steps {
                echo "Logging into Docker registry..."
                sh '''
                    echo ${DOCKER_CREDENTIALS_PSW} | docker login -u ${DOCKER_CREDENTIALS_USR} --password-stdin
                '''
            }
        }
        
        stage('Build') {
            steps {
                echo "Building Docker images..."
                sh '''
                    docker build -t ${DOCKER_USER}/palm-backend:${IMAGE_TAG} ./backend
                    docker build -t ${DOCKER_USER}/palm-frontend:${IMAGE_TAG} ./frontend
                    
                    # Also tag as 'latest'
                    docker tag ${DOCKER_USER}/palm-backend:${IMAGE_TAG} ${DOCKER_USER}/palm-backend:latest
                    docker tag ${DOCKER_USER}/palm-frontend:${IMAGE_TAG} ${DOCKER_USER}/palm-frontend:latest
                '''
            }
        }
        
        stage('Test-Build') {
            steps {
                echo "Listing Docker images..."
                sh 'docker images'
            }
        }
        
        stage('Push') {
            steps {
                echo "Pushing Docker images to registry..."
                sh '''
                    docker push ${DOCKER_USER}/palm-backend:${IMAGE_TAG}
                    docker push ${DOCKER_USER}/palm-frontend:${IMAGE_TAG}
                    
                    # Push 'latest' tags
                    docker push ${DOCKER_USER}/palm-backend:latest
                    docker push ${DOCKER_USER}/palm-frontend:latest
                '''
            }
        }
    }
}
