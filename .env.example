# Database
POSTGRES_USER=palmuser
POSTGRES_PASSWORD=palmpass
POSTGRES_DB=palmdb
DATABASE_URL=postgresql://palmuser:palmpass@postgres:5432/palmdb

# Application
SECRET_KEY=change-this-to-a-long-random-secret-key

# AWS S3 (optional — if not set, images are stored locally in uploads volume)
S3_BUCKET=your-palm-images-bucket
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# SMTP (required for password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_USE_TLS=true

# URLs
FRONTEND_URL=http://localhost

# Local uploads directory (used when S3 is not configured)
UPLOAD_DIR=/app/uploads
